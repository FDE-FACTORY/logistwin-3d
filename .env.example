# ── 백엔드(WebSocket 시뮬레이터) 환경변수 ──────────────────────
# Railway 등 배포 시 주입. 로컬은 기본값으로 동작(설정 불필요).

PORT=3001
# 허용 오리진 (쉼표로 여러 개). 프로덕션은 Vercel 프론트 도메인으로 제한 권장.
CORS_ORIGIN=*

# 시뮬레이션
SIM_SPEED=1
SIM_SEED=42
SIM_MODE=dual
# SIM_CRANE=standard          # compact | standard | highbay | heavyduty
# LAYOUT=generated/incheon-dc.layout.json   # 임포트한 평면도 레이아웃
# EXC_EVERY_TICKS=150         # 예외 주입 주기(틱)
# TMS_TRUCKS=6                # 가상 배송 트럭 수

# ── DB(선택) ───────────────────────────────────────────────────
# 설정하면 주문/이벤트를 Neon Postgres에 영속화. 없으면 in-memory + JSONL 이벤트로그.
# DATABASE_URL=postgres://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
